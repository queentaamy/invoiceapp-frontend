# ==============================================
# InvoiceFlow - Environment Variables (Example)
# Copy this file to .env and fill in your values
# ==============================================

# Override if you want to point at a different backend.
# Default backend used by the app is https://invoice-flow-cktz.onrender.com
VITE_API_BASE_URL=
# Optional local proxy target if you switch back to a local backend.
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_APP_NAME=InvoiceFlow
VITE_APP_VERSION=1.0.0
VITE_ENABLE_DEMO_MODE=false
